{
  "slug": "tech",
  "display_name": "Tech & Dev",
  "enabled": true,
  "filters": {
    "blocklist": ["nsfw", "giveaway", "promo code", "sponsored"],
    "relevance_keywords": ["ai", "ml", "model", "software", "developer", "code", "open source", "startup", "data", "cloud", "api", "release", "framework", "llm"],
    "relevance_threshold": 1,
    "max_age_days": 7,
    "dup_threshold": 0.8,
    "dup_window_days": 3
  },
  "prioritization": {
    "recency_weight": 0.5,
    "engagement_weight": 0.35,
    "sentiment_weight": 0.15,
    "half_life_hours": 24
  },
  "sources": {
    "hackernews": {
      "query": "",
      "limit": 30
    },
    "devto": {
      "tag": "technology",
      "limit": 15,
      "full_text": false
    },
    "github_releases": {
      "repos": ["python/cpython", "openai/openai-python", "langchain-ai/langchain"],
      "limit": 5
    },
    "arxiv": {
      "query": "cat:cs.AI OR cat:cs.LG",
      "limit": 20
    },
    "medium": {
      "category": "tech",
      "tags": ["technology", "programming"]
    },
    "producthunt": {
      "enabled": false,
      "limit": 20
    },
    "youtube": {
      "enabled": false,
      "query": "ai news",
      "limit": 5,
      "transcripts": true
    },
    "reddit": {
      "enabled": false,
      "subreddits": ["technology", "programming"],
      "sort": "hot",
      "limit": 15
    }
  }
}
