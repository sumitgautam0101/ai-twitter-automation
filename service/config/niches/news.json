{
  "slug": "news",
  "display_name": "News & Politics",
  "enabled": true,
  "filters": {
    "blocklist": ["nsfw", "clickbait", "you won't believe"],
    "relevance_keywords": [],
    "relevance_threshold": 1,
    "max_age_days": 2,
    "dup_threshold": 0.75
  },
  "prioritization": {
    "recency_weight": 0.7,
    "engagement_weight": 0.2,
    "sentiment_weight": 0.1,
    "half_life_hours": 8
  },
  "sources": {
    "gdelt": {
      "query": "breaking news",
      "limit": 30
    },
    "guardian": {
      "enabled": false,
      "section": "world",
      "limit": 20
    }
  }
}
